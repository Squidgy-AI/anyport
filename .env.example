# TokenRouter
TOKENROUTER_API_KEY=
TOKENROUTER_BASE_URL=https://api.tokenrouter.com/v1

# Reboot.dev (optional — only used by the legacy spawner path)
REBOOT_API_KEY=
REBOOT_BASE_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Local app URL
NEXT_PUBLIC_APP_URL=http://localhost:3040

# Public-facing tunnel URL (cloudflared / ngrok pointing at NEXT_PUBLIC_APP_URL).
# All MCP install URLs are constructed as ${ANYPORT_PUBLIC_URL}/api/mcp/<agentId>
# so claude.ai web (which requires HTTPS + permissive CORS) can reach them.
ANYPORT_PUBLIC_URL=

# Path to a directory of agent configs in the Squidgy YAML format.
# Each subdirectory should contain system_prompt.md + config.yaml.
SQUIDGY_AGENTS_DIR=

# UUID of the user whose connected accounts/tokens the n8n webhook should use.
# REQUIRED if any imported agent has an n8n webhook tool.
DEMO_USER_ID=
